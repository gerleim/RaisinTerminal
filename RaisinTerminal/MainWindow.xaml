<Window x:Class="RaisinTerminal.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:avalonDock="https://github.com/Dirkster99/AvalonDock"
        xmlns:views="clr-namespace:RaisinTerminal.Views"
        xmlns:vm="clr-namespace:RaisinTerminal.ViewModels"
        Title="RaisinTerminal"
        Icon="Assets/app.ico"
        Width="1200" Height="800"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        FontFamily="{DynamicResource MaterialDesignFont}">

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Control" Command="{Binding NewSessionCommand}"/>
        <KeyBinding Key="N" Modifiers="Control+Shift" Command="{Binding NewClaudeSessionCommand}"/>
    </Window.InputBindings>

    <DockPanel>
        <!-- Menu Bar -->
        <Menu DockPanel.Dock="Top" Background="#2D2D2D"
              materialDesign:MenuAssist.TopLevelMenuItemHeight="36">
            <MenuItem Header="_File">
                <MenuItem Header="_New Terminal" Command="{Binding NewSessionCommand}"
                          InputGestureText="Ctrl+N"/>
                <MenuItem Header="New _Claude Terminal" Command="{Binding NewClaudeSessionCommand}"
                          InputGestureText="Ctrl+Shift+N"/>
                <Separator/>
                <MenuItem Header="Add _Project..." Command="{Binding AddProjectCommand}"/>
                <MenuItem Header="Add _Group..." Command="{Binding AddGroupCommand}"/>
                <Separator/>
                <MenuItem Header="E_xit" Command="{Binding ExitCommand}"
                          InputGestureText="Alt+F4"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="_Projects Panel" IsCheckable="True"
                          IsChecked="{Binding ProjectsPanel.IsPanelVisible}"/>
            </MenuItem>
            <MenuItem Header="_Tools">
                <MenuItem Header="_Claude Code Update..." Command="{Binding ClaudeCodeUpdateCommand}"/>
                <Separator/>
                <MenuItem Header="_Options" Command="{Binding OptionsCommand}"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_Check for Updates..." Command="{Binding CheckForUpdatesCommand}"/>
                <Separator/>
                <MenuItem Header="_About" Command="{Binding AboutCommand}"/>
            </MenuItem>
        </Menu>

        <!-- Toolbar -->
        <ToolBar DockPanel.Dock="Top" Background="#2D2D2D" Height="36" Band="0" BandIndex="0">
            <ToggleButton Style="{StaticResource ToolbarIconToggleButton}"
                          IsChecked="{Binding ProjectsPanel.IsPanelVisible}"
                          ToolTip="Toggle Projects Panel">
                <materialDesign:PackIcon Kind="FolderMultiple" Width="20" Height="20"/>
            </ToggleButton>
            <Button Style="{StaticResource ToolbarIconButton}"
                    Command="{Binding NewSessionCommand}"
                    ToolTip="New Terminal (Ctrl+N)">
                <materialDesign:PackIcon Kind="Plus" Width="20" Height="20"/>
            </Button>
            <Button Style="{StaticResource ToolbarIconButton}"
                    Command="{Binding NewClaudeSessionCommand}"
                    ToolTip="New Claude Terminal (Ctrl+Shift+N)">
                <materialDesign:PackIcon Kind="Console" Width="20" Height="20"/>
            </Button>
            <Button Style="{StaticResource ToolbarIconButton}"
                    Command="{Binding AddProjectCommand}"
                    ToolTip="Add Project">
                <materialDesign:PackIcon Kind="FolderPlus" Width="20" Height="20"/>
            </Button>
            <Button Style="{StaticResource ToolbarIconButton}"
                    Command="{Binding AddGroupCommand}"
                    ToolTip="Add Group">
                <materialDesign:PackIcon Kind="FolderMultiplePlus" Width="20" Height="20"/>
            </Button>
        </ToolBar>

        <!-- Main content: Projects Panel + DockingManager -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="PanelColumn" MinWidth="150"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Projects Panel -->
            <views:ProjectsPanelView Grid.Column="0"
                                      DataContext="{Binding ProjectsPanel}"
                                      Visibility="{Binding IsPanelVisible, Converter={StaticResource BoolToVisConverter}}"/>

            <!-- Splitter -->
            <GridSplitter x:Name="PanelSplitter" Grid.Column="1" Width="3" Background="#3F3F46"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          DragCompleted="PanelSplitter_DragCompleted"
                          Visibility="{Binding ProjectsPanel.IsPanelVisible, Converter={StaticResource BoolToVisConverter}}"/>

            <!-- AvalonDock -->
            <avalonDock:DockingManager x:Name="DockingManager" Grid.Column="2" AllowMixedOrientation="True">
                <avalonDock:DockingManager.DocumentHeaderTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Title}"/>
                    </DataTemplate>
                </avalonDock:DockingManager.DocumentHeaderTemplate>
                <avalonDock:DockingManager.LayoutItemTemplateSelector>
                    <views:PaneTemplateSelector>
                        <views:PaneTemplateSelector.TerminalTemplate>
                            <DataTemplate DataType="{x:Type vm:TerminalSessionViewModel}">
                                <views:TerminalView/>
                            </DataTemplate>
                        </views:PaneTemplateSelector.TerminalTemplate>
                        <views:PaneTemplateSelector.ImageGalleryTemplate>
                            <DataTemplate DataType="{x:Type vm:ImageGalleryViewModel}">
                                <views:ImageGalleryView/>
                            </DataTemplate>
                        </views:PaneTemplateSelector.ImageGalleryTemplate>
                    </views:PaneTemplateSelector>
                </avalonDock:DockingManager.LayoutItemTemplateSelector>
                <avalonDock:DockingManager.LayoutItemContainerStyleSelector>
                    <views:PaneStyleSelector/>
                </avalonDock:DockingManager.LayoutItemContainerStyleSelector>
                <avalonDock:LayoutRoot>
                    <avalonDock:LayoutPanel Orientation="Horizontal">
                        <avalonDock:LayoutDocumentPane/>
                    </avalonDock:LayoutPanel>
                </avalonDock:LayoutRoot>
            </avalonDock:DockingManager>
        </Grid>
    </DockPanel>
</Window>
