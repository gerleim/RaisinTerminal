<UserControl x:Class="RaisinTerminal.Views.ProjectsPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:RaisinTerminal.ViewModels"
             Background="#1E1E1E">
    <UserControl.Resources>
        <!-- Status dot colors -->
        <SolidColorBrush x:Key="IdleBrush" Color="#888888"/>
        <SolidColorBrush x:Key="WorkingBrush" Color="#4EC862"/>
        <SolidColorBrush x:Key="WaitingBrush" Color="#E8A838"/>

        <Style x:Key="TreeViewItemStyle" TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="True"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <StackPanel>
                            <Border x:Name="Bd" Padding="{TemplateBinding Padding}"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter ContentSource="Header"/>
                            </Border>
                            <ItemsPresenter x:Name="ItemsHost" Margin="16,0,0,0"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="false">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A2D2E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Attachments folder node (non-expanding TreeViewItem style) -->
        <Style x:Key="AttachmentsFolderStyle" TargetType="TreeViewItem" BasedOn="{StaticResource TreeViewItemStyle}">
            <Setter Property="IsExpanded" Value="False"/>
        </Style>

        <!-- Terminal node template -->
        <DataTemplate x:Key="TerminalNodeTemplate" DataType="{x:Type vm:TerminalNodeViewModel}">
            <Border Padding="4,2" Cursor="Hand"
                    Background="Transparent">
                <StackPanel Orientation="Horizontal">
                    <Grid Width="12" Height="12" Margin="0,0,6,0" VerticalAlignment="Center">
                        <!-- Idle: Pause icon (two vertical bars) -->
                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Status}" Value="{x:Static vm:TerminalStatus.Working}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Status}" Value="{x:Static vm:TerminalStatus.WaitingForInput}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Canvas Width="12" Height="12" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Rectangle Canvas.Left="2" Canvas.Top="2" Width="2.5" Height="8"
                                           Fill="{StaticResource IdleBrush}" RadiusX="0.5" RadiusY="0.5"/>
                                <Rectangle Canvas.Left="7.5" Canvas.Top="2" Width="2.5" Height="8"
                                           Fill="{StaticResource IdleBrush}" RadiusX="0.5" RadiusY="0.5"/>
                            </Canvas>
                        </Grid>

                        <!-- Working: Rotating circular arrow -->
                        <Grid x:Name="WorkingGrid" RenderTransformOrigin="0.5,0.5" Visibility="Collapsed">
                            <Grid.RenderTransform>
                                <RotateTransform/>
                            </Grid.RenderTransform>
                            <Canvas Width="12" Height="12">
                                <Path Data="M 6,2 A 4,4 0 1 1 2,6"
                                      Stroke="{StaticResource WorkingBrush}" StrokeThickness="1.5"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Flat"/>
                                <Path Data="M 0.5,5.5 L 2,3 L 3.5,5.5 Z"
                                      Fill="{StaticResource WorkingBrush}"/>
                            </Canvas>
                        </Grid>

                        <!-- Waiting: Warning triangle with pulsing exclamation mark -->
                        <Grid Visibility="Collapsed" x:Name="WaitingGrid" RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Grid.RenderTransform>
                            <!-- Triangle outline -->
                            <Path Data="M 6,0.5 L 11.5,10.5 L 0.5,10.5 Z"
                                  Stroke="{StaticResource WaitingBrush}" StrokeThickness="1.2"
                                  StrokeLineJoin="Round" Fill="Transparent"/>
                            <!-- Exclamation mark -->
                            <Canvas Width="12" Height="12">
                                <Line X1="6" Y1="4" X2="6" Y2="7.5"
                                      Stroke="{StaticResource WaitingBrush}" StrokeThickness="1.5"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                <Ellipse Canvas.Left="5.1" Canvas.Top="8.5" Width="1.8" Height="1.8"
                                         Fill="{StaticResource WaitingBrush}"/>
                            </Canvas>
                        </Grid>
                    </Grid>
                    <TextBlock Text="{Binding Title}" Foreground="#CCCCCC" FontSize="12"
                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
            <!-- Animations at DataTemplate level — avoids WPF freezing Freezables inside Style setters -->
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static vm:TerminalStatus.Working}">
                    <Setter TargetName="WorkingGrid" Property="Visibility" Value="Visible"/>
                    <DataTrigger.EnterActions>
                        <BeginStoryboard x:Name="SpinStoryboard">
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="WorkingGrid"
                                                 Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                 From="0" To="360" Duration="0:0:1.2"
                                                 RepeatBehavior="Forever"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <StopStoryboard BeginStoryboardName="SpinStoryboard"/>
                    </DataTrigger.ExitActions>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static vm:TerminalStatus.WaitingForInput}">
                    <Setter TargetName="WaitingGrid" Property="Visibility" Value="Visible"/>
                    <DataTrigger.EnterActions>
                        <BeginStoryboard x:Name="PulseStoryboard">
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="WaitingGrid"
                                                 Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                 From="0.8" To="1.15" Duration="0:0:0.8"
                                                 AutoReverse="True" RepeatBehavior="Forever"/>
                                <DoubleAnimation Storyboard.TargetName="WaitingGrid"
                                                 Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                 From="0.8" To="1.15" Duration="0:0:0.8"
                                                 AutoReverse="True" RepeatBehavior="Forever"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <StopStoryboard BeginStoryboardName="PulseStoryboard"/>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <!-- Attachment item template -->
        <DataTemplate x:Key="AttachmentItemTemplate" DataType="{x:Type vm:AttachmentItemViewModel}">
            <Border Padding="4,2" Cursor="Hand" Background="Transparent">
                <Border.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Copy Path"
                                  Command="{Binding DataContext.CopyAttachmentPathCommand, Source={x:Reference ProjectsTree}}"
                                  CommandParameter="{Binding}"/>
                        <MenuItem Header="Open"
                                  Command="{Binding DataContext.OpenAttachmentCommand, Source={x:Reference ProjectsTree}}"
                                  CommandParameter="{Binding}"/>
                        <Separator/>
                        <MenuItem Header="Delete"
                                  Command="{Binding DataContext.DeleteAttachmentCommand, Source={x:Reference ProjectsTree}}"
                                  CommandParameter="{Binding}"/>
                    </ContextMenu>
                </Border.ContextMenu>
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftDoubleClick"
                                  Command="{Binding DataContext.OpenAttachmentCommand, Source={x:Reference ProjectsTree}}"
                                  CommandParameter="{Binding}"/>
                </Border.InputBindings>
                <StackPanel Orientation="Horizontal">
                    <!-- Image icon -->
                    <Canvas Width="12" Height="12" Margin="0,0,6,0" VerticalAlignment="Center">
                        <Rectangle Width="12" Height="12" Stroke="#AAAAAA" StrokeThickness="1" RadiusX="1" RadiusY="1"/>
                        <Path Data="M 1,9 L 4,6 L 6,8 L 8,5 L 11,9" Stroke="#AAAAAA" StrokeThickness="1"
                              StrokeLineJoin="Round"/>
                        <Ellipse Canvas.Left="2.5" Canvas.Top="2.5" Width="3" Height="3"
                                 Fill="#AAAAAA"/>
                    </Canvas>
                    <TextBlock Text="{Binding FileName}" Foreground="#AAAAAA" FontSize="11"
                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center">
                        <TextBlock.ToolTip>
                            <StackPanel MaxWidth="300">
                                <Image Source="{Binding FilePath}" MaxHeight="300" Stretch="Uniform"/>
                                <TextBlock Text="{Binding FilePath}" Foreground="#999"
                                           FontSize="10" TextWrapping="Wrap" Margin="0,4,0,0"/>
                            </StackPanel>
                        </TextBlock.ToolTip>
                    </TextBlock>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- Attachments folder header template -->
        <DataTemplate x:Key="AttachmentsFolderTemplate">
            <Border Padding="4,3" Background="Transparent">
                <StackPanel Orientation="Horizontal">
                    <!-- Paperclip icon -->
                    <Canvas Width="12" Height="14" Margin="0,0,6,0" VerticalAlignment="Center">
                        <Path Data="M 3,13 L 3,4 A 3,3 0 0 1 9,4 L 9,10 A 1.5,1.5 0 0 1 6,10 L 6,5"
                              Stroke="#AAAAAA" StrokeThickness="1.2" Fill="Transparent"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                    </Canvas>
                    <TextBlock Text="Attachments" Foreground="#AAAAAA" FontSize="11"
                               FontStyle="Italic" VerticalAlignment="Center"/>
                    <TextBlock Foreground="#666666" FontSize="10" Margin="6,0,0,0" VerticalAlignment="Center"
                               Text="{Binding Count, StringFormat='({0})'}"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- Project node template -->
        <HierarchicalDataTemplate x:Key="ProjectNodeTemplate" DataType="{x:Type vm:ProjectNodeViewModel}"
                                   ItemsSource="{Binding Terminals}"
                                   ItemTemplate="{StaticResource TerminalNodeTemplate}">
            <Border Padding="4,3" Background="Transparent">
                <Border.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="New Terminal Here"
                                  Command="{Binding DataContext.NewTerminalCommand, Source={x:Reference ProjectsTree}}"
                                  CommandParameter="{Binding}"/>
                        <MenuItem Header="New Claude Terminal Here"
                                  Command="{Binding DataContext.NewClaudeTerminalCommand, Source={x:Reference ProjectsTree}}"
                                  CommandParameter="{Binding}"/>
                        <MenuItem Header="Open slnx"
                                  Command="{Binding DataContext.OpenSlnxCommand, Source={x:Reference ProjectsTree}}"
                                  CommandParameter="{Binding}"
                                  Visibility="{Binding HasSlnx, Converter={StaticResource BoolToVisConverter}}"/>
                        <Separator/>
                        <MenuItem Header="Remove Project"
                                  Command="{Binding DataContext.RemoveProjectCommand, Source={x:Reference ProjectsTree}}"
                                  CommandParameter="{Binding}"/>
                        <Separator/>
                        <MenuItem Header="Properties"
                                  Command="{Binding DataContext.ProjectPropertiesCommand, Source={x:Reference ProjectsTree}}"
                                  CommandParameter="{Binding}"/>
                    </ContextMenu>
                </Border.ContextMenu>
                <StackPanel Orientation="Horizontal">
                    <!-- Expand/collapse toggle -->
                    <ToggleButton IsChecked="{Binding IsExpanded}" Width="16" Height="16" Margin="0,0,4,0"
                                  Background="Transparent" BorderThickness="0" Cursor="Hand"
                                  VerticalAlignment="Center">
                        <ToggleButton.Template>
                            <ControlTemplate TargetType="ToggleButton">
                                <Border Background="Transparent" Padding="2">
                                    <Path x:Name="Arrow" Fill="#999999" HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Data="M 0,0 L 5,4 L 0,8 Z"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="Arrow" Property="Data" Value="M 0,0 L 8,0 L 4,5 Z"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Arrow" Property="Fill" Value="#CCCCCC"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </ToggleButton.Template>
                    </ToggleButton>
                    <!-- App icon (when discovered) -->
                    <Image Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center"
                           Source="{Binding IconSource}" RenderOptions.BitmapScalingMode="HighQuality">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IconSource}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                    <!-- Fallback folder icon -->
                    <Canvas Width="14" Height="12" Margin="0,0,6,0" VerticalAlignment="Center">
                        <Canvas.Style>
                            <Style TargetType="Canvas">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IconSource}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Canvas.Style>
                        <Path Data="M 0,2 L 0,11 A 1,1 0 0 0 1,12 L 13,12 A 1,1 0 0 0 14,11 L 14,4 A 1,1 0 0 0 13,3 L 7,3 L 5.5,1 L 1,1 A 1,1 0 0 0 0,2 Z"
                              Fill="#AAAAAA"/>
                    </Canvas>
                    <TextBlock Text="{Binding Name}" Foreground="#E0E0E0" FontWeight="SemiBold" FontSize="12"
                               VerticalAlignment="Center"/>
                    <TextBlock Foreground="#888888" FontSize="11" Margin="6,0,0,0" VerticalAlignment="Center">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="({0})">
                                <Binding Path="Terminals.Count"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
            </Border>
        </HierarchicalDataTemplate>
    </UserControl.Resources>

    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#252526" Padding="8,6">
            <TextBlock Text="PROJECTS" Foreground="#888888" FontSize="11" FontWeight="SemiBold"/>
        </Border>

        <!-- Tree content -->
        <TreeView x:Name="ProjectsTree" Background="Transparent" BorderThickness="0"
                  Padding="4" ItemContainerStyle="{StaticResource TreeViewItemStyle}"
                  PreviewMouseLeftButtonUp="OnTreeMouseLeftButtonUp">
            <TreeView.Resources>
                <!-- Remove default highlight -->
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#CCCCCC"/>
            </TreeView.Resources>
        </TreeView>
    </DockPanel>
</UserControl>
