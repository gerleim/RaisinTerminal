<Window x:Class="RaisinTerminal.Views.RenameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rename Attachment"
        Width="360" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}">
    <StackPanel Margin="20">
        <TextBlock Text="New name:" Margin="0,0,0,6" FontSize="12"/>
        <DockPanel>
            <TextBlock x:Name="ExtensionText" DockPanel.Dock="Right" VerticalAlignment="Center"
                       Foreground="#888888" FontSize="13" Margin="2,0,0,0"/>
            <TextBox x:Name="NameBox" FontSize="13"
                     Background="#2A2A2A" Foreground="#DDDDDD" BorderBrush="#555555"
                     CaretBrush="#DDDDDD" Padding="4,3"/>
        </DockPanel>
        <TextBlock x:Name="ErrorText" Foreground="#FF6666" FontSize="11"
                   Margin="0,4,0,0" Visibility="Collapsed"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="OK" Width="80" IsDefault="True" Click="OnOk" Margin="0,0,8,0"/>
            <Button Content="Cancel" Width="80" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>
