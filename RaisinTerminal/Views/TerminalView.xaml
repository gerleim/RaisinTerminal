<UserControl x:Class="RaisinTerminal.Views.TerminalView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:RaisinTerminal.Controls"
             Background="#212121"
             Focusable="True"
             AllowDrop="True">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <controls:TerminalCanvas x:Name="Canvas"
                                 Grid.Column="0"
                                 Focusable="True"
                                 Cursor="IBeam"/>
        <!-- Input overlay for alternate screen mode (TUI apps) -->
        <Border x:Name="InputOverlay" Grid.Column="0"
                VerticalAlignment="Bottom"
                Visibility="Collapsed"
                Background="#2A2A2A"
                BorderBrush="#444444"
                BorderThickness="0,1,0,0"
                Padding="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="❯ "
                           Foreground="#888888"
                           FontFamily="Consolas"
                           FontSize="14"
                           VerticalAlignment="Top"
                           Margin="8,5,0,0"/>
                <TextBox x:Name="OverlayInput"
                         Grid.Column="1"
                         FontFamily="Consolas"
                         FontSize="14"
                         Background="#2A2A2A"
                         Foreground="#CCCCCC"
                         CaretBrush="#CCCCCC"
                         BorderThickness="0"
                         AcceptsReturn="False"
                         AcceptsTab="False"
                         TextWrapping="Wrap"
                         MaxHeight="120"
                         VerticalScrollBarVisibility="Auto"
                         Padding="0,4,8,4"/>
            </Grid>
        </Border>
        <ScrollBar x:Name="VerticalScrollBar"
                   Grid.Column="1"
                   Orientation="Vertical"
                   Minimum="0"
                   Maximum="0"
                   Value="0"
                   SmallChange="1"
                   LargeChange="10"
                   Visibility="Collapsed"
                   Focusable="False"
                   Width="14"
                   Background="#2A2A2A">
            <ScrollBar.Resources>
                <Style TargetType="RepeatButton">
                    <Setter Property="Background" Value="#2A2A2A"/>
                    <Setter Property="BorderBrush" Value="#2A2A2A"/>
                </Style>
            </ScrollBar.Resources>
        </ScrollBar>
    </Grid>
</UserControl>
