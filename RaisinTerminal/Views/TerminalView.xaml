<UserControl x:Class="RaisinTerminal.Views.TerminalView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:RaisinTerminal.Controls"
             Background="#212121"
             Focusable="True"
             AllowDrop="True">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <controls:TerminalCanvas x:Name="Canvas"
                                 Grid.Column="0"
                                 Focusable="True"
                                 Cursor="IBeam"/>
        <!-- Search bar overlay (Ctrl+F) -->
        <Border x:Name="SearchOverlay" Grid.Column="0"
                VerticalAlignment="Top"
                HorizontalAlignment="Right"
                Visibility="Collapsed"
                Background="#2A2A2A"
                BorderBrush="#444444"
                BorderThickness="1,0,0,1"
                CornerRadius="0,0,0,4"
                Padding="0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Find"
                           Foreground="#AAAAAA"
                           FontFamily="Consolas"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"/>
                <TextBox x:Name="SearchInput"
                         FontFamily="Consolas"
                         FontSize="14"
                         Background="#333333"
                         Foreground="#CCCCCC"
                         CaretBrush="#CCCCCC"
                         BorderThickness="1"
                         BorderBrush="#555555"
                         AcceptsReturn="False"
                         Padding="4,3,4,3"
                         Margin="6,4,4,4"
                         Width="200"/>
                <TextBlock x:Name="SearchResultsIndicator"
                           Text=""
                           Foreground="#888888"
                           FontFamily="Consolas"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="2,0,2,0"/>
                <Button x:Name="SearchUpButton"
                        Content="&#x25B2;" FontSize="10"
                        Width="24" Height="24"
                        BorderThickness="0" Margin="0,0,2,0"
                        Click="OnSearchUp" Focusable="False">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="2">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#444444"/>
                            <Setter Property="Foreground" Value="#CCCCCC"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#555555"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="SearchDownButton"
                        Content="&#x25BC;" FontSize="10"
                        Width="24" Height="24"
                        BorderThickness="0" Margin="0,0,6,0"
                        Click="OnSearchDown" Focusable="False">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="2">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#444444"/>
                            <Setter Property="Foreground" Value="#CCCCCC"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#555555"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="SearchCloseButton"
                        Content="&#x2715;" FontSize="12"
                        Width="24" Height="24"
                        BorderThickness="0" Margin="2,0,6,0"
                        Click="OnSearchClose" Focusable="False">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="2">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#999999"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#555555"/>
                                    <Setter Property="Foreground" Value="#CCCCCC"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>
        <!-- Input overlay for alternate screen mode (TUI apps) -->
        <Border x:Name="InputOverlay" Grid.Column="0"
                VerticalAlignment="Bottom"
                Visibility="Collapsed"
                Background="#2A2A2A"
                BorderBrush="#444444"
                BorderThickness="0,1,0,0"
                Padding="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="❯ "
                           Foreground="#888888"
                           FontFamily="Consolas"
                           FontSize="14"
                           VerticalAlignment="Top"
                           Margin="8,5,0,0"/>
                <TextBox x:Name="OverlayInput"
                         Grid.Column="1"
                         FontFamily="Consolas"
                         FontSize="14"
                         Background="#2A2A2A"
                         Foreground="#CCCCCC"
                         CaretBrush="#CCCCCC"
                         BorderThickness="0"
                         AcceptsReturn="False"
                         AcceptsTab="False"
                         TextWrapping="Wrap"
                         MaxHeight="120"
                         VerticalScrollBarVisibility="Auto"
                         Padding="0,4,8,4"/>
            </Grid>
        </Border>
        <ScrollBar x:Name="VerticalScrollBar"
                   Grid.Column="1"
                   Orientation="Vertical"
                   Minimum="0"
                   Maximum="0"
                   Value="0"
                   SmallChange="1"
                   LargeChange="10"
                   Visibility="Collapsed"
                   Focusable="False"
                   Width="14"
                   Background="#2A2A2A">
            <ScrollBar.Resources>
                <Style TargetType="RepeatButton">
                    <Setter Property="Background" Value="#2A2A2A"/>
                    <Setter Property="BorderBrush" Value="#2A2A2A"/>
                </Style>
            </ScrollBar.Resources>
        </ScrollBar>
    </Grid>
</UserControl>
