<Window x:Class="RaisinTerminal.Views.OptionsWindow"
       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       xmlns:settings="clr-namespace:Raisin.WPF.Base.Settings;assembly=Raisin.WPF.Base"
       Title="Options"
       Width="500" Height="400"
       WindowStartupLocation="CenterOwner"
       Background="{DynamicResource MaterialDesignPaper}"
       TextElement.Foreground="{DynamicResource MaterialDesignBody}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Raisin.WPF.Base;component/Themes/SettingsEditorTemplates.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <settings:SettingItemTemplateSelector x:Key="SettingItemSelector"
                CategoryHeaderTemplate="{StaticResource SharedCategoryHeaderTemplate}"
                BoolTemplate="{StaticResource SharedBoolTemplate}"
                IntTemplate="{StaticResource SharedIntTemplate}"
                DoubleTemplate="{StaticResource SharedDoubleTemplate}"
                StringTemplate="{StaticResource SharedStringTemplate}"
                TimeOnlyTemplate="{StaticResource SharedTimeOnlyTemplate}"
                ChoiceTemplate="{StaticResource SharedChoiceTemplate}"
                IntListTemplate="{StaticResource SharedIntListTemplate}"
                OffsetTemplate="{StaticResource SharedOffsetTemplate}"
                TimePairTemplate="{StaticResource SharedTimePairTemplate}"
                IntPairTemplate="{StaticResource SharedIntPairTemplate}"
                DoublePairTemplate="{StaticResource SharedDoublePairTemplate}"/>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel Margin="16">
        <!-- Buttons at bottom -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="OK" Width="80" IsDefault="True" Click="OnOk" Margin="0,0,8,0"/>
            <Button Content="Cancel" Width="80" IsCancel="True" Click="OnCancel"/>
        </StackPanel>

        <!-- Settings list -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding DisplayItems}"
                          ItemTemplateSelector="{StaticResource SettingItemSelector}"/>
        </ScrollViewer>
    </DockPanel>
</Window>
