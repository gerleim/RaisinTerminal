<Window x:Class="RaisinTerminal.Views.GroupNameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Group Name"
        Width="350" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}">
    <StackPanel Margin="20">
        <TextBlock Text="Name" FontSize="12" Foreground="#AAAAAA" Margin="0,0,0,4"/>
        <TextBox x:Name="NameBox" FontSize="12"
                 Background="#2A2D2E" Foreground="#E0E0E0" BorderBrush="#444444"
                 Padding="6,4" Margin="0,0,0,20"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="80" IsDefault="True" Click="OnOk" Margin="0,0,8,0"/>
            <Button Content="Cancel" Width="80" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>
