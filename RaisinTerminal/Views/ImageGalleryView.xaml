<UserControl x:Class="RaisinTerminal.Views.ImageGalleryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:RaisinTerminal.Views"
             xmlns:conv="clr-namespace:RaisinTerminal.Converters"
             Background="#1A1A1A">
    <UserControl.Resources>
        <local:PathToFileNameConverter x:Key="PathToFileName"/>
        <conv:FilePathToImageConverter x:Key="FilePathToImage"/>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" MinWidth="120"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left panel: file list -->
        <DockPanel Grid.Column="0">
            <!-- Toolbar -->
            <Border DockPanel.Dock="Top" Background="#252526" Padding="4,3">
                <StackPanel Orientation="Horizontal">
                    <Button Command="{Binding OpenInExplorerCommand}" ToolTip="Open folder in Explorer"
                            Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="4,2">
                        <Canvas Width="14" Height="14">
                            <Path Data="M 0,2 L 0,12 A 1,1 0 0 0 1,13 L 13,13 A 1,1 0 0 0 14,12 L 14,4 A 1,1 0 0 0 13,3 L 7,3 L 5.5,1 L 1,1 A 1,1 0 0 0 0,2 Z"
                                  Fill="#AAAAAA"/>
                        </Canvas>
                    </Button>
                    <Button Command="{Binding DeleteAttachmentCommand}" ToolTip="Delete selected"
                            Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="4,2">
                        <Canvas Width="14" Height="14">
                            <Path Data="M 3,4 L 3,12 L 11,12 L 11,4 M 1,3 L 13,3 M 5,1 L 9,1 L 9,3 L 5,3 Z M 5.5,5.5 L 5.5,10.5 M 8.5,5.5 L 8.5,10.5"
                                  Stroke="#AAAAAA" StrokeThickness="1" Fill="Transparent"/>
                        </Canvas>
                    </Button>
                    <Button Command="{Binding CopyPathCommand}" ToolTip="Copy path"
                            Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="4,2">
                        <Canvas Width="14" Height="14">
                            <Path Data="M 3,1 L 10,1 L 10,10 L 3,10 Z" Stroke="#AAAAAA" StrokeThickness="1" Fill="Transparent"/>
                            <Path Data="M 5,4 L 12,4 L 12,13 L 5,13 Z" Stroke="#AAAAAA" StrokeThickness="1" Fill="Transparent"/>
                        </Canvas>
                    </Button>
                </StackPanel>
            </Border>

            <ListBox x:Name="ImageListBox"
                     ItemsSource="{Binding ImagePaths}"
                     SelectedItem="{Binding SelectedImage}"
                     Background="Transparent"
                     BorderThickness="0"
                     Foreground="#AAAAAA"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="4,2">
                            <Border Width="32" Height="32" Margin="0,0,6,0" Background="#252526" CornerRadius="2">
                                <Image Source="{Binding Converter={StaticResource FilePathToImage}}" Stretch="Uniform"/>
                            </Border>
                            <TextBlock Text="{Binding Converter={StaticResource PathToFileName}}"
                                       Foreground="#AAAAAA" FontSize="11"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding}"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="2"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#2A2D2E"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#2A2D2E"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </DockPanel>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" Width="3" Background="#333333"
                      HorizontalAlignment="Center" VerticalAlignment="Stretch"
                      ResizeBehavior="PreviousAndNext"/>

        <!-- Right panel: image preview -->
        <Border Grid.Column="2" Background="#111111">
            <Image Source="{Binding SelectedImage, Converter={StaticResource FilePathToImage}}" Stretch="Uniform" Margin="8"
                   RenderOptions.BitmapScalingMode="HighQuality"/>
        </Border>
    </Grid>
</UserControl>
